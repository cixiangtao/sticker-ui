          "path": "src/components/ui/checkbox.tsx",
          "target": "@ui/checkbox.tsx",
          "type": "registry:ui"
        }
      ]
    },
    {
      "name": "radio",
      "type": "registry:ui",
      "title": "Sticker Radio",
      "description": "A Radix-powered radio group with tactile sticker items and selected states.",
      "dependencies": ["@radix-ui/react-radio-group"],
      "registryDependencies": ["utils"],
      "files": [
        {
          "path": "src/components/ui/radio.tsx",
          "target": "@ui/radio.tsx",
          "type": "registry:ui"
        }
      ]
    },
    {
      "name": "switch",
      "type": "registry:ui",
      "title": "Sticker Switch",
      "description": "A Radix-powered switch with a tactile sticker track and paper thumb.",
      "dependencies": ["@radix-ui/react-switch"],
      "registryDependencies": ["utils"],
      "files": [
        {
          "path": "src/components/ui/switch.tsx",
          "target": "@ui/switch.tsx",
          "type": "registry:ui"
        }
      ]
    },
    {
      "name": "form",
      "type": "registry:ui",
      "title": "Sticker Form",
      "description": "An antd-style form controller with handbook sticker field states.",
      "registryDependencies": ["utils", "label"],
      "files": [
        {
          "path": "src/components/ui/form.tsx",
          "target": "@ui/form.tsx",
          "type": "registry:ui"
        }
      ]
    }
  ]
}
