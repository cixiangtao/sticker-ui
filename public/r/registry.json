{
  "$schema": "https://ui.shadcn.com/schema/registry.json",
  "name": "sticker-ui",
  "homepage": "https://example.com",
  "items": [
    {
      "name": "utils",
      "type": "registry:lib",
      "title": "Sticker Utils",
      "description": "Shared className utilities for Sticker UI components.",
      "dependencies": ["clsx", "tailwind-merge"],
      "files": [
        {
          "path": "src/lib/utils.ts",
          "target": "@lib/utils.ts",
          "type": "registry:lib"
        }
      ]
    },
    {
      "name": "button",
      "type": "registry:ui",
      "title": "Sticker Button",
      "description": "A tactile handbook sticker button with chunky ink borders.",
      "dependencies": ["@radix-ui/react-slot", "class-variance-authority"],
      "registryDependencies": ["utils"],
      "files": [
        {
          "path": "src/components/ui/button.tsx",
          "target": "@ui/button.tsx",
          "type": "registry:ui"
        }
      ]
    },
    {
      "name": "card",
      "type": "registry:ui",
      "title": "Sticker Card",
      "description": "A composable handbook sticker surface for cards, panels, and grouped content.",
      "dependencies": ["@radix-ui/react-slot", "class-variance-authority"],
      "registryDependencies": ["utils"],
      "files": [
        {
          "path": "src/components/ui/card.tsx",
          "target": "@ui/card.tsx",
          "type": "registry:ui"
        }
      ]
    },
    {
      "name": "table",
      "type": "registry:ui",
      "title": "Sticker Table",
      "description": "A scrollable paper table frame for API references and structured data.",
      "registryDependencies": ["utils"],
      "files": [
        {
          "path": "src/components/ui/table.tsx",
          "target": "@ui/table.tsx",
          "type": "registry:ui"
        }
      ]
    },
    {
      "name": "tag",
      "type": "registry:ui",
      "title": "Sticker Tag",
      "description": "A compact sticker tag for statuses, labels, and metadata chips.",
      "dependencies": ["class-variance-authority"],
      "registryDependencies": ["utils"],
      "files": [
        {
          "path": "src/components/ui/tag.tsx",
          "target": "@ui/tag.tsx",
          "type": "registry:ui"
        }
      ]
    },
    {
      "name": "alert",
      "type": "registry:ui",
      "title": "Sticker Alert",
      "description": "A readable sticker note for status messages and feedback.",
      "dependencies": ["class-variance-authority"],
      "registryDependencies": ["utils"],
      "files": [
        {
          "path": "src/components/ui/alert.tsx",
          "target": "@ui/alert.tsx",
          "type": "registry:ui"
        }
      ]
    },
    {
      "name": "label",
      "type": "registry:ui",
      "title": "Sticker Label",
      "description": "An accessible form caption with optional sticker markers.",
      "dependencies": ["class-variance-authority"],
      "registryDependencies": ["utils"],
      "files": [
        {
          "path": "src/components/ui/label.tsx",
          "target": "@ui/label.tsx",
          "type": "registry:ui"
        }
      ]
    },
    {
      "name": "input",
      "type": "registry:ui",
      "title": "Sticker Input",
      "description": "A native form input with chunky sticker frames and semantic field states.",
      "dependencies": ["class-variance-authority"],
      "registryDependencies": ["utils"],
      "files": [
        {
          "path": "src/components/ui/input.tsx",
          "target": "@ui/input.tsx",
          "type": "registry:ui"
        }
      ]
    },
    {
      "name": "input-password",
      "type": "registry:ui",
      "title": "Sticker Password Input",
      "description": "A password field with a sticker frame and show-hide visibility toggle.",
