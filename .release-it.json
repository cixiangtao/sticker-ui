{
  "$schema": "https://unpkg.com/release-it@20/schema/release-it.json",
  "git": {
    "commit": true,
    "commitMessage": "chore(release): v${version}",
    "tag": true,
    "tagName": "v${version}",
    "push": true,
    "requireCleanWorkingDir": true
  },
  "github": {
    "release": false
  },
  "gitlab": {
    "release": false
  },
  "hooks": {
    "before:init": "pnpm run release:check",
    "after:release": "echo Successfully released ${name} v${version}"
  },
  "npm": {
    "publish": true,
    "publishArgs": [
      "--access",
      "public",
      "--publish-branch",
      "main",
      "--no-git-checks"
    ],
    "publishPackageManager": "pnpm"
  }
}
