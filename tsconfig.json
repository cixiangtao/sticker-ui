{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "ignoreDeprecations": "6.0",
    "paths": {
      "@anys/tanstack-route-kit": [
        "./packages/tanstack-route-kit/src/index.ts"
      ],
      "@/*": ["./src/*"],
      "sticker-ui": ["./src/index.ts"],
      "*": ["./*"],
      "~/*": ["./*"]
    }
  },
  "include": [
    "src",
    "tests",
    "packages",
    "registry",
    "vite.config.ts",
    "tsdown.config.ts",
    "components.json",
    "registry.json"
  ]
}
