{
  "name": "sticker-ui",
  "version": "1.0.0-beta.0",
  "description": "A source-first handbook sticker style React + Tailwind component registry.",
  "files": [
    "dist",
    "src/components",
    "src/lib",
    "registry.json"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./tokens.css": "./dist/tokens.css",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vp dev",
    "build": "pnpm run build:packages && pnpm run build:lib && pnpm run build:registry && pnpm run build:preview",
    "build:api": "node scripts/build-api-docs.mjs",
    "build:lib": "tsdown && node scripts/copy-package-assets.mjs",
    "build:packages": "pnpm --filter @anys/tanstack-route-kit build",
    "build:registry": "shadcn build",
    "build:preview": "pnpm run build:api && pnpm run check && vp build",
    "prepack": "pnpm run build:lib",
    "prepare": "vp config",
    "preview": "vp preview",
    "release": "release-it",
    "release:check": "pnpm run lint && pnpm run build:registry && pnpm run test && pnpm run verify:package && git diff --exit-code -- registry.json public/r && pnpm publish --dry-run --access public --publish-branch main",
    "release:dry": "release-it --dry-run",
    "check": "tsc --noEmit",
    "format": "vp fmt . --write",
    "format:check": "vp fmt . --check",
    "lint": "pnpm run check && pnpm run format:check && vp lint .",
    "lint:fix": "pnpm run format && vp lint . --fix && pnpm run check",
    "test": "vp test run",
    "verify:package": "pnpm run build:lib && node scripts/verify-package-exports.mjs"
  },
  "dependencies": {
    "@colordx/core": "^5.5.0",
    "@radix-ui/react-accordion": "^1.2.16",
    "@radix-ui/react-alert-dialog": "^1.1.17",
    "@radix-ui/react-aspect-ratio": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.4",
    "@radix-ui/react-collapsible": "^1.1.16",
    "@radix-ui/react-context-menu": "^2.3.1",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-hover-card": "^1.1.19",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-menubar": "^1.1.20",
    "@radix-ui/react-navigation-menu": "^1.2.16",
    "@radix-ui/react-popover": "^1.1.16",
    "@radix-ui/react-radio-group": "^1.4.1",
    "@radix-ui/react-scroll-area": "^1.2.14",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-slider": "^1.4.3",
    "@radix-ui/react-slot": "^1.2.5",
    "@radix-ui/react-switch": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.15",
    "@radix-ui/react-toggle": "^1.1.14",
    "@radix-ui/react-toggle-group": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.9",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.21.0",
    "react-resizable-panels": "^4.12.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@anys/tanstack-route-kit": "workspace:*",
    "@babel/core": "^7.29.7",
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@locator/babel-jsx": "^0.5.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/vite": "latest",
    "@tanstack/react-router": "^1.170.15",
    "@types/node": "^25.9.3",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "latest",
    "babel-plugin-react-compiler": "1.0.0",
    "i18next": "^26.3.1",
    "react": "latest",
    "react-dom": "latest",
    "react-i18next": "^17.0.8",
    "release-it": "^20.2.1",
    "shadcn": "latest",
    "shiki": "^4.2.0",
    "tailwindcss": "latest",
    "tailwindcss-animate": "^1.0.7",
    "ts-morph": "^28.0.0",
    "tsdown": "^0.22.4",
    "typescript": "7.0.2",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "tailwindcss": "^4.0.0"
  },
  "packageManager": "pnpm@10.17.1"
}
