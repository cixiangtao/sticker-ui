{
  "name": "sticker-ui",
  "version": "0.1.0",
  "packageManager": "pnpm@10.17.1",
  "type": "module",
  "description": "A source-first handbook sticker style React + Tailwind component registry.",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./tokens.css": "./dist/tokens.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src/components",
    "src/lib",
    "registry.json"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "pnpm run build:packages && pnpm run build:lib && pnpm run build:registry && pnpm run build:preview",
    "build:api": "node scripts/build-api-docs.mjs",
    "build:lib": "tsdown && node scripts/copy-package-assets.mjs",
    "build:packages": "pnpm --filter @anys/tanstack-route-kit build",
    "build:registry": "shadcn build",
    "build:preview": "pnpm run build:api && pnpm run check && vite build",
    "prepack": "pnpm run build:lib",
    "prepare": "husky",
    "preview": "vite preview",
    "check": "tsc --noEmit",
    "format": "oxfmt . --write",
    "format:check": "oxfmt . --check",
    "lint": "pnpm run check && pnpm run format:check && oxlint .",
    "lint:fix": "pnpm run format && oxlint . --fix && pnpm run check"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "tailwindcss": "^4.0.0"
  },
  "devDependencies": {
    "@anys/tanstack-route-kit": "workspace:*",
    "@babel/core": "^7.29.7",
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@locator/babel-jsx": "^0.5.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/vite": "latest",
    "@tanstack/react-router": "^1.170.15",
    "@types/node": "^25.9.3",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "latest",
    "husky": "^9.1.7",
    "i18next": "^26.3.1",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "react": "latest",
    "react-dom": "latest",
    "react-i18next": "^17.0.8",
    "shadcn": "latest",
    "shiki": "^4.2.0",
    "tailwindcss": "latest",
    "tailwindcss-animate": "^1.0.7",
    "ts-morph": "^28.0.0",
    "tsdown": "^0.22.3",
    "typescript": "latest",
    "vite": "^8.0.16"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.17",
    "@radix-ui/react-checkbox": "^1.3.4",
    "@radix-ui/react-context-menu": "^2.3.1",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-navigation-menu": "^1.2.16",
    "@radix-ui/react-popover": "^1.1.16",
    "@radix-ui/react-radio-group": "^1.4.1",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-slot": "^1.2.5",
    "@radix-ui/react-switch": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.9",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.21.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0"
  }
}
