{
  "name": "sticker-ui",
  "version": "0.1.0",
  "packageManager": "pnpm@10.17.1",
  "type": "module",
  "description": "A source-first handbook sticker style React + Tailwind component registry.",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./tokens.css": "./dist/tokens.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "registry",
    "registry.json"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "pnpm run build:lib && pnpm run build:registry && pnpm run build:preview",
    "build:api": "node scripts/build-api-docs.mjs",
    "build:lib": "tsup && node scripts/copy-package-assets.mjs",
    "build:registry": "shadcn build",
    "build:preview": "pnpm run build:api && tsc --noEmit && vite build",
    "prepack": "pnpm run build:lib",
    "preview": "vite preview",
    "check": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "pnpm run check && pnpm run format:check && eslint .",
    "lint:fix": "prettier --write . && eslint . --fix && pnpm run check"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "tailwindcss": "^4.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@eslint/js": "^10.0.1",
    "@locator/babel-jsx": "^0.5.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/vite": "latest",
    "@tanstack/react-router": "^1.170.15",
    "@types/node": "^25.9.3",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "latest",
    "eslint": "^10.4.1",
    "eslint-plugin-perfectionist": "^5.9.0",
    "i18next": "^26.3.1",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "react": "latest",
    "react-dom": "latest",
    "react-i18next": "^17.0.8",
    "shadcn": "latest",
    "shiki": "^4.2.0",
    "tailwindcss": "latest",
    "ts-morph": "^28.0.0",
    "tsup": "^8.5.1",
    "typescript": "latest",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.4",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-popover": "^1.1.16",
    "@radix-ui/react-slot": "^1.2.5",
    "@radix-ui/react-switch": "^1.3.0",
    "@radix-ui/react-tooltip": "^1.2.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.6.0"
  }
}
