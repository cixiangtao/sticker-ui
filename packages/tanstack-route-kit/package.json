{
  "name": "@anys/tanstack-route-kit",
  "version": "0.1.0",
  "type": "module",
  "description": "Config-first helpers for TanStack React Router route trees, metadata, and route-derived navigation.",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsdown",
    "check": "tsc --noEmit"
  },
  "peerDependencies": {
    "@tanstack/react-router": "^1.170.15",
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@tanstack/react-router": "^1.170.15",
    "@types/react": "latest",
    "react": "latest",
    "tsdown": "^0.22.3",
    "typescript": "latest"
  }
}
